{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@mvp/ui": ["../../packages/ui/src"],
      "@mvp/ui/*": ["../../packages/ui/src/*"],
      "@mvp/store": ["../../packages/store/src"],
      "@mvp/store/*": ["../../packages/store/src/*"],
      "@mvp/i18n": ["../../packages/i18n/src"],
      "@mvp/i18n/*": ["../../packages/i18n/src/*"],
      "@mvp/lib": ["../../packages/lib/src"],
      "@mvp/lib/*": ["../../packages/lib/src/*"],
      "@mvp/analytics": ["../../packages/analytics/src"],
      "@mvp/analytics/*": ["../../packages/analytics/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../../packages/*/src/**/*.ts",
    "../../packages/*/src/**/*.tsx"
  ]
}
