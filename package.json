{
  "name": "mvptemplate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "docker": "docker compose -f apps/backend/docker/docker-compose.dev.yml up -d",
    "docker:stop": "docker compose -f apps/backend/docker/docker-compose.dev.yml down",
    "update-ip": "node scripts/update-ip.mjs",
    "restart": "node scripts/restart.mjs",
    "dev": "node scripts/update-ip.mjs && turbo dev --filter=mobile --filter=backend",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:backend": "npm run dev -w apps/backend",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "npm run db:push -w apps/backend",
    "clean": "turbo clean && rm -rf node_modules",
    "generate-env": "node scripts/generate-env.mjs",
    "setup": "npm install && node scripts/generate-env.mjs",
    "test": "vitest run",
    "test:backend": "vitest run --project backend",
    "test:store": "vitest run --project store",
    "test:lib": "vitest run --project lib",
    "test:i18n": "vitest run --project i18n",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:visual": "npx playwright test tests/e2e/visual.spec.ts",
    "test:e2e:visual:update": "npx playwright test tests/e2e/visual.spec.ts --update-snapshots",
    "test:e2e:ext": "npx playwright test --config=playwright.extension.config.ts",
    "dev:extension": "npm run dev -w apps/extension",
    "build:extension": "npm run build -w apps/extension",
    "gitpush": "git push origin HEAD"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.0.1",
    "turbo": "^2.4.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "tar": ">=7.5.8",
    "minimatch": ">=3.1.3"
  },
  "dependencies": {
    "expo-dev-client": "~6.0.20"
  }
}
